# Copy to .env.local and fill in. Never commit .env.local — it holds secrets.

# Claude — generates the behaviour read (server-side only)
ANTHROPIC_API_KEY=
# Optional model override; defaults to claude-sonnet-4-6
MODEL=

# Resend — sends the read by email (server-side only)
RESEND_API_KEY=
# Sender address. Leave blank in dev to use Resend's sandbox sender
# (onboarding@resend.dev). TODO(launch): set to a verified-domain address,
# e.g. "Companion <reads@yourdomain.com>".
RESEND_FROM=

# Postgres — stores saved reads (nickname + email + result only). Use a
# pooled connection string on serverless hosts (Neon / Vercel Postgres / Supabase).
DATABASE_URL=

# Public base URL used for email links (sign-in, delete-my-data).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secret for signing magic-link tokens and session cookies (server-side only).
# Generate one with: openssl rand -base64 32
SESSION_SECRET=
